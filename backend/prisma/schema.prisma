
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Schedule {
  id            Int      @id @default(autoincrement())
  route         String   // "Kyiv-Malyn-Irpin", "Malyn-Kyiv-Irpin", "Kyiv-Malyn-Bucha", "Malyn-Kyiv-Bucha"
  departureTime String   // Формат "HH:MM" (наприклад "08:00")
  maxSeats      Int      @default(20) // Максимальна кількість місць
  supportPhone  String?  // Телефон підтримки для уточнення бронювання (напр. +380(93) 170 18 35), для напрямків з Києвом
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([route, departureTime])
}

// Єдина база людей: прив'язка номера до імені та Telegram для всіх сценаріїв
model Person {
  id                    Int       @id @default(autoincrement())
  phoneNormalized       String    @unique // Нормалізований номер (380XXXXXXXXX)
  fullName              String?   // Ім'я та прізвище
  telegramChatId        String?   // Для відправки повідомлень в Telegram
  telegramUserId        String?   // Ідентифікатор користувача в Telegram
  telegramPromoSentAt     DateTime? // Коли одноразово відправлено промо від вашого акаунта (щоб не спамити)
  telegramReminderSentAt  DateTime? // Остання дата нагадування/реклами для Telegram-клієнтів (щоб не спамити)
  createdAt               DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  bookings     Booking[]
  viberListings ViberListing[]
  viberRideEvents ViberRideEvent[]
}

model Booking {
  id              Int       @id @default(autoincrement())
  route           String
  date            DateTime
  departureTime   String   // Час відправлення у форматі "HH:MM"
  seats           Int
  name            String   // Денормалізовано для відображення; джерело істини — Person
  phone           String   // Денормалізовано; джерело істини — Person.phoneNormalized
  telegramChatId  String?  // Копія з Person для зворотної сумісності
  telegramUserId  String?  // Копія з Person для зворотної сумісності
  scheduleId      Int?     // Посилання на графік (опціонально)
  personId        Int?     // Посилання на людину (єдине джерело імені/телефону/Telegram)
  source          String   @default("schedule") // "schedule" — маршрутка, "viber_match" — попутка (водій підтвердив)
  viberListingId  Int?     // Якщо source=viber_match — оголошення водія (ViberListing)
  createdAt       DateTime @default(now())

  person       Person?       @relation(fields: [personId], references: [id], onDelete: SetNull)
  viberListing ViberListing? @relation(fields: [viberListingId], references: [id], onDelete: SetNull)
}

// Запит пасажира на бронювання у водія (пряме співпадіння). Водій має 1 год на підтвердження.
model RideShareRequest {
  id                  Int      @id @default(autoincrement())
  passengerListingId  Int
  driverListingId     Int
  status              String   // "pending" | "confirmed" | "expired" | "rejected"
  expiresAt           DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  passengerListing ViberListing @relation("RideShareAsPassenger", fields: [passengerListingId], references: [id], onDelete: Cascade)
  driverListing    ViberListing @relation("RideShareAsDriver", fields: [driverListingId], references: [id], onDelete: Cascade)
}

model ViberListing {
  id            Int      @id @default(autoincrement())
  rawMessage    String   @db.Text // Оригінальне повідомлення з чату
  senderName    String?  // Ім'я відправника (деноралізовано; джерело — Person)
  listingType   String   // "driver" або "passenger"
  route         String   // Напрямок (наприклад "Київ-Малин", "Малин-Київ")
  date          DateTime // Дата поїздки
  departureTime String?  // Час відправлення (може бути діапазон "18:00-18:30")
  seats         Int?     // Кількість місць (для пасажира) або вільних місць (для водія)
  phone         String   // Контактний номер (деноралізовано; джерело — Person)
  notes         String?  // Додаткові примітки (наприклад "від м Почайна")
  priceUah      Int?     // Ціна в гривнях (опціонально)
  isActive      Boolean  @default(true) // Чи активне оголошення
  personId      Int?     // Посилання на людину
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  person                   Person?            @relation(fields: [personId], references: [id], onDelete: SetNull)
  bookingsFromRideShare    Booking[]
  rideShareRequestsAsPassenger RideShareRequest[] @relation("RideShareAsPassenger")
  rideShareRequestsAsDriver   RideShareRequest[] @relation("RideShareAsDriver")
}

/// Аналітичні події, згенеровані з історичної таблиці "ViberRide" (окремий сервіс парсингу).
/// Кожен рядок = одна "подія поїздки" з прив'язкою до телефону/Person та часовими ознаками.
model ViberRideEvent {
  id              Int       @id @default(autoincrement())
  /// Первинний ключ з історичної таблиці "ViberRide"
  viberRideId     Int
  /// Телефон з вихідних даних (як є)
  contactPhone    String
  /// Нормалізований телефон (380XXXXXXXXX) для зв'язку з Person
  phoneNormalized String
  /// Зв'язок з єдиною базою людей (може бути відсутній, якщо Person ще не створений)
  personId        Int?

  /// Напрямок (наприклад "Kyiv-Malyn", "Malyn-Kyiv") — з "ViberRide.route"
  route           String?
  /// Дата поїздки
  departureDate   DateTime?
  /// Час/інтервал відправлення у вихідному вигляді (наприклад "18:00" або "18:00-18:30")
  departureTime   String?
  /// Кількість вільних/потрібних місць
  availableSeats  Int?
  /// Ціна в гривнях (якщо вдалося розпарсити)
  priceUah        Int?
  /// Чи успішно розпарсено повідомлення
  isParsed        Boolean
  /// Чи вважається поїздка "активною" у вихідній таблиці (може бути відсутнє)
  isActive        Boolean?
  /// Текстова інформація про помилки парсингу
  parsingErrors   String?

  /// День тижня (0–6) за датою поїздки, для швидкої аналітики
  weekday         Int?
  /// Година відправлення (0–23) — початок інтервалу, якщо був діапазон
  hour            Int?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  person          Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@unique([viberRideId])
}
