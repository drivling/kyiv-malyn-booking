{
  "name": "kyiv-malyn-backend",
  "scripts": {
    "dev": "ts-node-dev src/index.ts",
    "build": "rm -rf dist && prisma generate && tsc",
    "start": "prisma migrate deploy && node dist/index.js",
    "prisma:init": "prisma init",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
"fix-telegram-ids": "ts-node src/fix-telegram-ids.ts",
    "migrate-to-person": "ts-node src/migrate-to-person.ts",
    "test": "node -r ./test-pretest.cjs -r ts-node/register --test src/viber-parser.test.ts src/telegram.test.ts src/telegram.prisma.test.ts src/telegram.bot.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "node-telegram-bot-api": "^0.67.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node-telegram-bot-api": "^0.64.7",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
